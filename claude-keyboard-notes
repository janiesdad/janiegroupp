function CloudFBM() {
  const mesh = useRef<THREE.Mesh>(null);
  const { viewport } = useThree();
  const { analyser } = useContext(AudioContextProvider);
  const dataArray = useRef<Uint8Array>();

  const uniforms = useMemo(
    () => ({
      u_resolution: { value: new THREE.Vector2() },
      u_pixelRatio: {
        value:
          typeof window !== "undefined"
            ? window.devicePixelRatio
            : 1,
      },
      u_time: { value: 0.1 },
      u_scale: { value: 2.5 },
      u_color1: {
        value: new THREE.Vector3(0.08, 0.12, 0.24),
      },
      u_color2: { value: new THREE.Vector3(0.25, 0.35, 0.65) },
      u_color3: { value: new THREE.Vector3(0.55, 0.75, 0.95) },
      u_color4: { value: new THREE.Vector3(0.9, 0.95, 1.0) },
      u_octaves: { value: 6.0 },
      u_persistence: { value: 0.5 },
      u_lacunarity: { value: 2.0 },
      u_volume: { value: 0.0 },
      u_frequency: { value: 0.0 },
      u_bass: { value: 0.0 },
      u_mid: { value: 0.0 },
      u_treble: { value: 0.0 },
    }),
    [],
  );

  // Initialize frequency data array
  useEffect(() => {
    if (analyser) {
      dataArray.current = new Uint8Array(
        analyser.frequencyBinCount,
      );
    }
  }, [analyser]);

  useFrame((state) => {
    const { clock } = state;
    if (mesh.current) {
      // Update audio-reactive uniforms first to get volume
      let currentVolume = 0;

      if (analyser && dataArray.current) {
        analyser.getByteFrequencyData(dataArray.current);

        // Calculate overall volume
        const volume =
          dataArray.current.reduce(
            (sum, value) => sum + value,
            0,
          ) /
          dataArray.current.length /
          255;

        currentVolume = volume;

        // Calculate frequency bands
        const bassEnd = Math.floor(
          dataArray.current.length * 0.1,
        );
        const midEnd = Math.floor(
          dataArray.current.length * 0.4,
        );

        const bass =
          dataArray.current
            .slice(0, bassEnd)
            .reduce((sum, value) => sum + value, 0) /
          bassEnd /
          255;
        const mid =
          dataArray.current
            .slice(bassEnd, midEnd)
            .reduce((sum, value) => sum + value, 0) /
          (midEnd - bassEnd) /
          255;
        const treble =
          dataArray.current
            .slice(midEnd)
            .reduce((sum, value) => sum + value, 0) /
          (dataArray.current.length - midEnd) /
          255;

        // Find dominant frequency
        const maxIndex = dataArray.current.indexOf(
          Math.max(...dataArray.current),
        );
        const frequency = maxIndex / dataArray.current.length;

        // Update uniforms with smoothing
        mesh.current.material.uniforms.u_volume.value =
          THREE.MathUtils.lerp(
            mesh.current.material.uniforms.u_volume.value,
            volume,
            0.1,
          );
        mesh.current.material.uniforms.u_frequency.value =
          THREE.MathUtils.lerp(
            mesh.current.material.uniforms.u_frequency.value,
            frequency,
            0.1,
          );
        mesh.current.material.uniforms.u_bass.value =
          THREE.MathUtils.lerp(
            mesh.current.material.uniforms.u_bass.value,
            bass,
            0.1,
          );
        mesh.current.material.uniforms.u_mid.value =
          THREE.MathUtils.lerp(
            mesh.current.material.uniforms.u_mid.value,
            mid,
            0.1,
          );
        mesh.current.material.uniforms.u_treble.value =
          THREE.MathUtils.lerp(
            mesh.current.material.uniforms.u_treble.value,
            treble,
            0.1,
          );

        // Make colors more vibrant and cloud-like based on audio
        const intensity = volume * 1.5;

        // Dark blue base (night sky)
        mesh.current.material.uniforms.u_color1.value.set(
          0.08 + bass * 0.15,
          0.12 + bass * 0.2,
          0.24 + bass * 0.3,
        );

        // Medium blue (cloud shadows)
        mesh.current.material.uniforms.u_color2.value.set(
          0.25 + mid * 0.2,
          0.35 + mid * 0.25,
          0.65 + mid * 0.2,
        );

        // Light blue (cloud body)
        mesh.current.material.uniforms.u_color3.value.set(
          0.55 + treble * 0.25,
          0.75 + treble * 0.15,
          0.95 + treble * 0.05,
        );

        // Bright white (cloud highlights)
        mesh.current.material.uniforms.u_color4.value.set(
          0.9 + intensity * 0.1,
          0.95 + intensity * 0.05,
          1.0,
        );

        // Adjust FBM parameters based on audio
        mesh.current.material.uniforms.u_scale.value =
          2.5 + volume * 1.0;
        mesh.current.material.uniforms.u_octaves.value =
          6.0 + bass * 1.0;
        mesh.current.material.uniforms.u_persistence.value =
          0.5 + treble * 0.3;
        mesh.current.material.uniforms.u_lacunarity.value =
          2.0 + mid * 0.5;
      }

      // Audio-reactive time scaling with faster base speed
      const baseSpeed = 0.2; // Faster base speed for more dynamic movement
      const audioSpeedMultiplier = 1 + currentVolume * 5; // Scale up when audio is present
      const finalSpeed = baseSpeed * audioSpeedMultiplier;

      // Update time with audio-reactive speed
      mesh.current.material.uniforms.u_time.value =
        clock.getElapsedTime() * finalSpeed;

      mesh.current.material.uniforms.u_resolution.value.set(
        200 *
          (typeof window !== "undefined"
            ? window.devicePixelRatio
            : 1),
        200 *
          (typeof window !== "undefined"
            ? window.devicePixelRatio
            : 1),
      );
    }
  });

  const vertexShader = `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `;

  const fragmentShader = `
    uniform float u_time;
    uniform vec2 u_resolution;
    uniform float u_scale;
    uniform vec3 u_color1;
    uniform vec3 u_color2;
    uniform vec3 u_color3;
    uniform vec3 u_color4;
    uniform float u_octaves;
    uniform float u_persistence;
    uniform float u_lacunarity;
    uniform float u_pixelRatio;
    uniform float u_volume;
    uniform float u_frequency;
    uniform float u_bass;
    uniform float u_mid;
    uniform float u_treble;
    varying vec2 vUv;

    vec4 permute(vec4 x){return mod(((x*34.0)+1.0)*x, 289.0);}
    vec4 taylorInvSqrt(vec4 r){return 1.79284291400159 - 0.85373472095314 * r;}
    vec3 fade(vec3 t) {return t*t*t*(t*(t*6.0-15.0)+10.0);}

    float cnoise(vec3 P){
      vec3 Pi0 = floor(P);
      vec3 Pi1 = Pi0 + vec3(1.0);
      Pi0 = mod(Pi0, 289.0);
      Pi1 = mod(Pi1, 289.0);
      vec3 Pf0 = fract(P);
      vec3 Pf1 = Pf0 - vec3(1.0);
      vec4 ix = vec4(Pi0.x, Pi1.x, Pi0.x, Pi1.x);
      vec4 iy = vec4(Pi0.yy, Pi1.yy);
      vec4 iz0 = Pi0.zzzz;
      vec4 iz1 = Pi1.zzzz;
      vec4 ixy = permute(permute(ix) + iy);
      vec4 ixy0 = permute(ixy + iz0);
      vec4 ixy1 = permute(ixy + iz1);
      vec4 gx0 = ixy0 / 7.0;
      vec4 gy0 = fract(floor(gx0) / 7.0) - 0.5;
      gx0 = fract(gx0);
      vec4 gz0 = vec4(0.5) - abs(gx0) - abs(gy0);
      vec4 sz0 = step(gz0, vec4(0.0));
      gx0 -= sz0 * (step(0.0, gx0) - 0.5);
      gy0 -= sz0 * (step(0.0, gy0) - 0.5);
      vec4 gx1 = ixy1 / 7.0;
      vec4 gy1 = fract(floor(gx1) / 7.0) - 0.5;
      gx1 = fract(gx1);
      vec4 gz1 = vec4(0.5) - abs(gx1) - abs(gy1);
      vec4 sz1 = step(gz1, vec4(0.0));
      gx1 -= sz1 * (step(0.0, gx1) - 0.5);
      gy1 -= sz1 * (step(0.0, gy1) - 0.5);
      vec3 g000 = vec3(gx0.x,gy0.x,gz0.x);
      vec3 g100 = vec3(gx0.y,gy0.y,gz0.y);
      vec3 g010 = vec3(gx0.z,gy0.z,gz0.z);
      vec3 g110 = vec3(gx0.w,gy0.w,gz0.w);
      vec3 g001 = vec3(gx1.x,gy1.x,gz1.x);
      vec3 g101 = vec3(gx1.y,gy1.y,gz1.y);
      vec3 g011 = vec3(gx1.z,gy1.z,gz1.z);
      vec3 g111 = vec3(gx1.w,gy1.w,gz1.w);
      vec4 norm0 = taylorInvSqrt(vec4(dot(g000, g000), dot(g010, g010), dot(g100, g100), dot(g110, g110)));
      g000 *= norm0.x;
      g010 *= norm0.y;
      g100 *= norm0.z;
      g110 *= norm0.w;
      vec4 norm1 = taylorInvSqrt(vec4(dot(g001, g001), dot(g011, g011), dot(g101, g101), dot(g111, g111)));
      g001 *= norm1.x;
      g011 *= norm1.y;
      g101 *= norm1.z;
      g111 *= norm1.w;
      float n000 = dot(g000, Pf0);
      float n100 = dot(g100, vec3(Pf1.x, Pf0.yz));
      float n010 = dot(g010, vec3(Pf0.x, Pf1.y, Pf0.z));
      float n110 = dot(g110, vec3(Pf1.xy, Pf0.z));
      float n001 = dot(g001, vec3(Pf0.xy, Pf1.z));
      float n101 = dot(g101, vec3(Pf1.x, Pf0.y, Pf1.z));
      float n011 = dot(g011, vec3(Pf0.x, Pf1.yz));
      float n111 = dot(g111, Pf1);
      vec3 fade_xyz = fade(Pf0);
      vec4 n_z = mix(vec4(n000, n100, n010, n110), vec4(n001, n101, n011, n111), fade_xyz.z);
      vec2 n_yz = mix(n_z.xy, n_z.zw, fade_xyz.y);
      float n_xyz = mix(n_yz.x, n_yz.y, fade_xyz.x);   
      return 2.18 * n_xyz;
    }

    // Fractal Brownian Motion function for cloud-like patterns
    float fbm(vec3 p) {
      float value = 0.0;
      float amplitude = 0.5;
      float frequency = 1.0;
      
      for (float i = 0.0; i < u_octaves; i++) {
        value += amplitude * cnoise(p * frequency);
        frequency *= u_lacunarity;
        amplitude *= u_persistence;
      }
      
      return value;
    }

    // Ridged noise for more defined cloud edges
    float ridgedNoise(vec3 p) {
      return 1.0 - abs(cnoise(p));
    }

    float ridgedFBM(vec3 p) {
      float value = 0.0;
      float amplitude = 0.5;
      float frequency = 1.0;
      
      for (float i = 0.0; i < u_octaves * 0.5; i++) {
        value += amplitude * ridgedNoise(p * frequency);
        frequency *= u_lacunarity;
        amplitude *= u_persistence;
      }
      
      return value;
    }

    void main() {
      vec2 screenCoord = gl_FragCoord.xy / u_resolution.xy;
      
      // Add audio-reactive effects to the noise coordinates
      float audioWarp = u_volume * 0.3;
      float frequencyShift = u_frequency * 1.2;
      
      // Base FBM coordinates with time animation
      vec3 fbmCoords = vec3(screenCoord * u_scale, u_time * 0.5);
      
      // Add audio-reactive warping
      fbmCoords.xy += audioWarp;
      fbmCoords.z += frequencyShift;
      
      // Add bass-driven vertical flow
      fbmCoords.y += sin(screenCoord.x * 4.0 + u_time * 2.0) * u_bass * 0.5;
      
      // Add treble-driven turbulence
      fbmCoords += vec3(
        sin(screenCoord.y * 8.0 + u_time * 3.0) * u_treble * 0.3,
        cos(screenCoord.x * 6.0 + u_time * 2.5) * u_treble * 0.3,
        0.0
      );
      
      // Add mid-frequency swirling motion
      float angle = u_time * 1.5 + length(screenCoord - 0.5) * 8.0;
      fbmCoords.xy += vec2(cos(angle), sin(angle)) * u_mid * 0.4;
      
      // Generate multiple layers of FBM for cloud depth
      float fbm1 = fbm(fbmCoords);
      float fbm2 = fbm(fbmCoords * 2.1 + vec3(100.0, 50.0, 25.0));
      float fbm3 = ridgedFBM(fbmCoords * 0.8 + vec3(200.0, 100.0, 50.0));
      
      // Combine layers for cloud-like structure
      float cloudDensity = fbm1 * 0.5 + fbm2 * 0.3 + fbm3 * 0.2;
      
      // Normalize and enhance contrast
      cloudDensity = (cloudDensity + 1.0) * 0.5; // Normalize from [-1,1] to [0,1]
      cloudDensity = smoothstep(0.1, 0.9, cloudDensity);
      
      // Audio-reactive density modulation
      float densityModulation = 1.0 + sin(u_time * 3.0) * u_volume * 0.4;
      cloudDensity *= densityModulation;
      
      // Create smooth color transitions using smoothstep
      vec3 finalColor;
      
      if (cloudDensity < 0.25) {
        // Dark sky
        finalColor = mix(u_color1, u_color2, smoothstep(0.0, 0.25, cloudDensity));
      } else if (cloudDensity < 0.5) {
        // Cloud shadows
        finalColor = mix(u_color2, u_color3, smoothstep(0.25, 0.5, cloudDensity));
      } else if (cloudDensity < 0.75) {
        // Cloud body
        finalColor = mix(u_color3, u_color4, smoothstep(0.5, 0.75, cloudDensity));
      } else {
        // Cloud highlights
        finalColor = u_color4;
      }
      
      // Add subtle shimmer effect based on audio
      float shimmer = sin(screenCoord.x * 20.0 + u_time * 8.0) * sin(screenCoord.y * 15.0 + u_time * 6.0);
      finalColor += shimmer * u_treble * 0.1 * cloudDensity;
      
      gl_FragColor = vec4(finalColor, 1.0);
    }
  `;

  return (
    <mesh
      ref={mesh}
      scale={[viewport.width, viewport.height, 1]}
    >
      <planeGeometry args={[1, 1]} />
      <shaderMaterial
        fragmentShader={fragmentShader}
        vertexShader={vertexShader}
        uniforms={uniforms}
      />
    </mesh>
  );
}

